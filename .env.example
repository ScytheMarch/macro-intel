# FRED API key (free at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# Optional: override default paths
# MACRO_INTEL_DB_PATH=./data/macro_intel.db
# MACRO_INTEL_MODEL_DIR=./data/models
# MACRO_INTEL_REPORTS_DIR=./data/reports

# Optional: lookback period
# MACRO_INTEL_LOOKBACK_YEARS=10

# Optional: PyMC sampling config
# PYMC_DRAWS=2000
# PYMC_TUNE=1000
# PYMC_CHAINS=4
